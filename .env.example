# Copy to `.env` on the VM and fill in real credentials.

ANTHROPIC_API_KEY=replace-me
GOOGLE_API_KEY=replace-me
BRAVE_API_KEY=replace-me

# Optional. Used only by the in-container Codex CLI for OpenAI usage-based billing.
OPENAI_API_KEY=

# Optional legacy fallback if `config/models.yaml` is missing.
CONDUIT_MODEL=claude-opus-4-6

# Host-side port binding for Docker Compose.
# Set this to the VM's Tailscale IP to keep the API private to your tailnet.
CONDUIT_PUBLISH_IP=127.0.0.1
